#ifndef ES8388_H
#define ES8388_H

#include <Wire.h>

#define ES8388_ADDR 0x10

class ES8388 {
public:
    static bool begin(int sda, int scl) {
        Wire.begin(sda, scl);
        delay(100);
        
        Serial.println("[ES8388] Initializing codec - ESP-ADF sequence...");
        
        // Reset completo
        writeReg(0x00, 0x80);  // Reset
        writeReg(0x00, 0x00);  // Clear reset
        delay(100);
        
        // Sequência ESP-ADF oficial
        writeReg(0x01, 0x58);  // CONTROL1: VMIDSEL=50k
        writeReg(0x02, 0x50);  // CONTROL2: VREF setup
        writeReg(0x02, 0x00);  // CHIPPOWER: Power up all
        writeReg(0x03, 0x00);  // ADCPOWER: Power down ADC (bit 0-7 = 0 liga DAC)
        
        // Disable internal DLL para melhorar sample rate
        writeReg(0x35, 0xA0);
        writeReg(0x37, 0xD0);
        writeReg(0x39, 0xD0);
        
        writeReg(0x08, 0x00);  // MASTERMODE: Slave mode
        writeReg(0x00, 0x12);  // CONTROL1: Play mode
        
        // DAC Control - Sequência conforme ESP-ADF oficial
        writeReg(0x04, 0xC0);  // DACPOWER: Primeiro desabilita DAC e saídas
        writeReg(0x17, 0x18);  // DACCONTROL1: 16-bit I2S format
        writeReg(0x18, 0x02);  // DACCONTROL2: Single speed, ratio 256
        writeReg(0x1A, 0x00);  // DACCONTROL16: Audio on LIN1&RIN1
        
        // CRÍTICO: Tentar valor alternativo 0x09 para registrador 0x26
        // 0x90 não funciona neste hardware, testar 0x09 (LD2LO + LI2LO)
        writeReg(0x26, 0x09);  // DACCONTROL17: Left DAC to left mixer
        delay(50);
        writeReg(0x27, 0x90);  // DACCONTROL20: Right DAC to right mixer (0x90 = 0dB)
        delay(50);
        writeReg(0x2A, 0x80);  // DACCONTROL21: Internal LRCK
        writeReg(0x2B, 0x00);  // DACCONTROL23: VROI=0
        
        // Output volume L1/R1/L2/R2 (0x1E = 0dB)
        writeReg(0x2E, 0x1E);  // DACCONTROL24: LOUT1 volume
        writeReg(0x2F, 0x1E);  // DACCONTROL25: ROUT1 volume
        writeReg(0x30, 0x00);  // DACCONTROL26: LOUT2 volume (muted)
        writeReg(0x31, 0x00);  // DACCONTROL27: ROUT2 volume (muted)
        
        // CRÍTICO: Habilitar DAC e saídas LOUT1/ROUT1 (conforme ESP-ADF)
        // 0x3C = DAC_OUTPUT_LOUT1 | DAC_OUTPUT_ROUT1 | DAC_OUTPUT_LOUT2 | DAC_OUTPUT_ROUT2
        // 0x0C = DAC_OUTPUT_LOUT1 | DAC_OUTPUT_ROUT1 (apenas LOUT1/ROUT1)
        writeReg(0x04, 0x3C);  // DACPOWER: Enable DAC + LOUT1/2 + ROUT1/2
        
        // ADC Power - desabilitado
        writeReg(0x09, 0xFF);  // ADCPOWER: Power down ADC
        
        delay(100);
        
        // CRÍTICO: Configurar formato I2S antes de qualquer reprodução
        configureI2SFormat();
        
        // Verificar configuração de mixer
        uint8_t verify26 = readReg(0x26);
        uint8_t verify27 = readReg(0x27);
        uint8_t verify04 = readReg(0x04);
        Serial.printf("[ES8388] Mixer check - 0x26: 0x%02X, 0x27: 0x%02X, 0x04: 0x%02X\n", 
                     verify26, verify27, verify04);
        
        // CRÍTICO: Bug do ES8388 - registrador 0x26 não mantém valor 0x90
        // Tentar valor alternativo 0x09 que pode funcionar neste hardware
        if (verify26 != 0x09 && verify26 != 0x90) {
            Serial.println("[ES8388] ⚠ Reg 0x26 incorrect, trying alternative value 0x09...");
            for (int i = 0; i < 3; i++) {
                writeReg(0x26, 0x09);
                delay(50);
                verify26 = readReg(0x26);
                Serial.printf("[ES8388] Attempt %d - Reg 0x26: 0x%02X\n", i+1, verify26);
                if (verify26 == 0x09) {
                    Serial.println("[ES8388] ✓ Using 0x09 for left mixer");
                    break;
                }
            }
        }
        
        Serial.println("[ES8388] ✓ Codec initialized with ESP-ADF sequence");
        return true;
    }
    
    static void setVolume(uint8_t volume) {
        if (volume > 33) volume = 33;
        // Registradores corretos de volume de saída (LOUT1/ROUT1)
        writeReg(0x2E, volume);  // LOUT1VOL
        writeReg(0x2F, volume);  // ROUT1VOL
        writeReg(0x30, volume);  // LOUT2VOL
        writeReg(0x31, volume);  // ROUT2VOL
        Serial.printf("[ES8388] Volume set to %d (all outputs)\n", volume);
    }
    
    static void configureI2SFormat() {
        Serial.println("[ES8388] Configuring I2S format for ESP32-audioI2S compatibility...");
        
        // Registro 0x08 (Master Mode Control)
        // Bit 7 = 0: Slave mode (ESP32 é I2S master)
        // Bit 6 = 0: BCLK not inverted
        // Bit 5 = 0: MCLK disabled (ESP32-audioI2S não usa MCLK)
        // Bits [4:0] = 00000: Reserved
        writeReg(0x08, 0x00);
        
        // Registro 0x17 (DAC Control 1 - Audio Format)
        // Bit 7-6 = 00: Reserved
        // Bit 5 = 0: DACLRC polarity normal
        // Bit 4-3 = 11: I2S format (Philips standard)
        // Bits 2-0 = 000: 16-bit word length
        // 0x18 = 0b00011000
        writeReg(0x17, 0x18);
        
        // Registro 0x18 (DAC Control 2 - Sample Rate)
        // Bits 7-5 = 000: MCLK/LRCK ratio = 256 (para 44.1kHz)
        // Bits 4-2 = 000: Reserved
        // Bit 1 = 1: Single speed mode (8kHz - 48kHz)
        // Bit 0 = 0: Reserved
        // 0x02 = 0b00000010
        writeReg(0x18, 0x02);
        
        // Registro 0x1A (DAC Control 16 - DAC Source)
        // Bit 7 = 0: Reserved
        // Bit 6 = 0: Soft ramp disabled (evita cliques)
        // Bit 5 = 0: DAC normal operation (não muted)
        // Bits 4-2 = 000: Reserved
        // Bits 1-0 = 00: DAC data source from I2S interface
        // 0x00 = 0b00000000
        writeReg(0x1A, 0x00);
        
        delay(50);
        
        // Verificar configuração
        uint8_t verify08 = readReg(0x08);
        uint8_t verify17 = readReg(0x17);
        uint8_t verify18 = readReg(0x18);
        uint8_t verify1A = readReg(0x1A);
        
        Serial.println("[ES8388] I2S Format Configuration:");
        Serial.printf("[ES8388]   Reg 0x08 (Master Mode): 0x%02X %s\n", verify08,
                     verify08 == 0x00 ? "✓ Slave mode" : "⚠ Check mode");
        Serial.printf("[ES8388]   Reg 0x17 (DAC Ctrl 1): 0x%02X %s\n", verify17,
                     verify17 == 0x18 ? "✓ I2S 16-bit" : "⚠ Format issue");
        Serial.printf("[ES8388]   Reg 0x18 (DAC Ctrl 2): 0x%02X %s\n", verify18,
                     verify18 == 0x02 ? "✓ Single speed" : "⚠ Sample rate issue");
        Serial.printf("[ES8388]   Reg 0x1A (DAC Source): 0x%02X %s\n", verify1A,
                     verify1A == 0x00 ? "✓ I2S source" : "⚠ Source issue");
        
        if (verify08 == 0x00 && verify17 == 0x18 && verify18 == 0x02 && verify1A == 0x00) {
            Serial.println("[ES8388] ✓ I2S format configured correctly");
        } else {
            Serial.println("[ES8388] ⚠ I2S format configuration mismatch - audio may have noise/distortion");
        }
    }
    
    static void diagnose() {
        Serial.println("[ES8388] ========== DIAGNOSTIC REPORT ==========");
        
        // Ler registradores críticos
        uint8_t reg02 = readReg(0x02);  // Power Management 1
        uint8_t reg03 = readReg(0x03);  // Power Management 2
        uint8_t reg04 = readReg(0x04);  // Power Management 3
        uint8_t reg26 = readReg(0x26);  // LMIXSEL
        uint8_t reg27 = readReg(0x27);  // RMIXSEL
        uint8_t reg2E = readReg(0x2E);  // LOUT1VOL
        uint8_t reg2F = readReg(0x2F);  // ROUT1VOL
        uint8_t reg30 = readReg(0x30);  // LOUT2VOL
        uint8_t reg31 = readReg(0x31);  // ROUT2VOL
        
        Serial.printf("[ES8388] Reg 0x02 (Power Mgmt 1): 0x%02X %s\n", reg02, 
                     reg02 == 0x00 ? "✓ All powered" : "⚠ Check power");
        Serial.printf("[ES8388] Reg 0x03 (Power Mgmt 2): 0x%02X %s\n", reg03,
                     reg03 == 0x00 ? "✓ DAC L/R enabled" : "⚠ DAC issue");
        Serial.printf("[ES8388] Reg 0x04 (Power Mgmt 3): 0x%02X %s\n", reg04,
                     reg04 == 0x3C ? "✓ DAC + outputs ON" : "⚠ Check power config");
        Serial.printf("[ES8388] Reg 0x26 (LMIXSEL): 0x%02X %s\n", reg26,
                     (reg26 == 0x90 || reg26 == 0x09) ? "✓ LDAC routed" : "⚠ Left mixer issue");
        Serial.printf("[ES8388] Reg 0x27 (RMIXSEL): 0x%02X %s\n", reg27,
                     reg27 == 0x90 ? "✓ RDAC routed" : "⚠ Right mixer issue");
        Serial.printf("[ES8388] Reg 0x2E (LOUT1VOL): 0x%02X (%.1f dB)\n", reg2E, (reg2E * 1.5) - 48.0);
        Serial.printf("[ES8388] Reg 0x2F (ROUT1VOL): 0x%02X (%.1f dB)\n", reg2F, (reg2F * 1.5) - 48.0);
        Serial.printf("[ES8388] Reg 0x30 (LOUT2VOL): 0x%02X (%.1f dB)\n", reg30, (reg30 * 1.5) - 48.0);
        Serial.printf("[ES8388] Reg 0x31 (ROUT2VOL): 0x%02X (%.1f dB)\n", reg31, (reg31 * 1.5) - 48.0);
        
        Serial.println("[ES8388] ===============================================");
    }
    
private:
    static void writeReg(uint8_t reg, uint8_t val) {
        Wire.beginTransmission(ES8388_ADDR);
        Wire.write(reg);
        Wire.write(val);
        Wire.endTransmission();
        delayMicroseconds(100);
    }
    
    static uint8_t readReg(uint8_t reg) {
        Wire.beginTransmission(ES8388_ADDR);
        Wire.write(reg);
        Wire.endTransmission(false);
        Wire.requestFrom(ES8388_ADDR, 1);
        if (Wire.available()) {
            return Wire.read();
        }
        return 0xFF;  // Erro de leitura
    }
};

#endif
